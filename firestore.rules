rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Common auth check
    function isOwner(data) {
      return request.auth != null && data.userId == request.auth.uid;
    }

    function isAdmin() {
      // In a real app, use custom claims or an admin collection.
      // For this demo, allow access based on a specific email.
      return request.auth != null && request.auth.token.email == 'admin@barbequenation.com';
    }

    match /orders/{document} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data) || isAdmin();
    }
    
    match /bookings/{document} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data) || isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
